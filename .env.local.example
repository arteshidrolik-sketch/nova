# Bu dosyayı ".env.local" olarak kopyala ve anahtarını gir.
# .env.local repoya GİTMEZ (.gitignore'da).

# Claude API anahtarın (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Kullanılacak model (opsiyonel). Varsayılan: claude-opus-4-8
# Daha ucuz/hızlı için: claude-sonnet-4-6
NOVA_MODEL=claude-opus-4-8

# (Opsiyonel) Yönlendirme/hafıza için ayrı model — boşsa NOVA_MODEL kullanılır
# NOVA_ROUTER_MODEL=claude-haiku-4-5

# (Opsiyonel) GitHub aracı için salt-okuma token. Yoksa public repolar sınırlı
# oranla çalışır. https://github.com/settings/tokens (fine-grained, Contents: Read)
GITHUB_TOKEN=

# (Opsiyonel) Haftalık brifing loop'unun commit çekeceği repo: "sahip/depo"
# NOVA_BRIEF_REPO=vercel/next.js

# (Opsiyonel) Zamanlayıcıyı kapatmak için: off
# NOVA_SCHEDULER=off
